          "last_updated": "2026-02-17",
          "attachment": true,
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
          "knowledge": "2025-08",
          "open_weights": false,
          "cost": {
            "input": 3,
            "output": 15,
            "cache_read": 0.3,
            "cache_write": 3.75,
            "context_over_200k": {
              "input": 6,
              "output": 22.5,
              "cache_read": 0.6,
              "cache_write": 7.5
            }
          },
          "limit": {
            "context": 200000,
            "output": 64000
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          }
        },
