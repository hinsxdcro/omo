{
  "plugin": ["oh-my-opencode@latest"],
  "provider": {
    "openai": {
      "options": {
        "baseURL": "{env:OPENAI_BASEURL}",
        "apiKey": "{env:OPENAI_API_KEY}"
      }
    },
    "anthropic": {
      "options": {
        "baseURL": "{env:ANTHROPIC_BASEURL}",
        "apiKey": "{env:ANTHROPIC_API_KEY}"
      },
      "models": {
        "global.anthropic.claude-sonnet-4-6": {
